[TestSlogEntryAttrs/with_claim_failures - 1]
{
 "authorization": {
  "authorized": false
 },
 "level": "AUDIT",
 "msg": "audit_event",
 "request": {
  "method": "",
  "path": "",
  "sourceIP": "",
  "status": 0,
  "userAgent": ""
 },
 "token": {
  "attemptedPatterns": [
   {
    "claim": "pipeline_slug",
    "pattern": ".*-release",
    "value": "silk-staging"
   }
  ],
  "requestedRepository": "https://github.com/org/repo"
 }
}
