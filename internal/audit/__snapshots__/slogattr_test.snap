  "hashedToken": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
  "matches": [
   {
    "claim": "pipeline_slug",
    "value": "main-pipeline"
   }
  ],
  "permissions": [
   "contents:read"
  ],
  "repositories": [
   "org/repo"
  ],
  "requestedProfile": "org/repo",
  "requestedRepository": "https://github.com/org/repo",
  "vendedRepository": "https://github.com/org/vended-repo"
 }
}
