[TestSlogEntryAttrs/with_claim_matches - 1]
{
 "authorization": {
  "authorized": false
 },
 "level": "AUDIT",
 "msg": "audit_event",
 "request": {
  "method": "",
  "path": "",
  "sourceIP": "",
  "status": 0,
  "userAgent": ""
 },
 "token": {
  "matches": [
   {
    "claim": "pipeline_slug",
    "value": "silk-prod"
   },
   {
    "claim": "build_branch",
    "value": "main"
   }
  ],
  "requestedRepository": "https://github.com/org/repo"
 }
}
